---
import { useTranslations } from '../i18n/ui';

export interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="fitur" class="py-20 px-4 bg-surface-bg border-t border-surface-card transition-colors duration-500">
  <div class="max-w-7xl mx-auto scroll-reveal">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-brand-primary font-bold tracking-widest uppercase text-sm mb-2 block">{t('features.badge')}</span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-surface-text mb-4">{t('features.title')}</h2>
      <p class="text-surface-muted">{t('features.desc')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
      
      <!-- Card 1: Large (AI YOLO) -->
      <div class="md:col-span-2 bg-surface-card p-6 md:p-10 rounded-3xl flex flex-col justify-end min-h-[320px] relative overflow-hidden group border border-surface-border shadow-sm hover:shadow-lg transition-all duration-300">
        
        <div class="absolute top-6 right-4 md:top-10 md:right-10 w-32 h-20 md:w-48 md:h-32 flex gap-1.5 md:gap-2 items-end opacity-30 md:opacity-80 pointer-events-none">
            <div class="w-1/4 bg-brand-primary/20 rounded-t-md h-1/3 animate-[pulse_2s_ease-in-out_infinite_0s] relative overflow-hidden"></div>
            <div class="w-1/4 bg-brand-primary/20 rounded-t-md h-2/3 animate-[pulse_2s_ease-in-out_infinite_0.5s]"></div>
            <div class="w-1/4 bg-brand-primary/40 rounded-t-md h-full animate-[pulse_2s_ease-in-out_infinite_1.5s]"></div>
            <div class="w-1/4 bg-brand-primary/20 rounded-t-md h-1/2 animate-[pulse_2s_ease-in-out_infinite_1s]"></div>
            <div class="absolute -inset-x-4 top-1/2 h-0.5 bg-brand-primary/50 shadow-glow-blue animate-[ping_3s_ease-in-out_infinite]"></div>
        </div>

        <div class="relative z-10 mt-20 md:mt-0 h-full flex flex-col justify-end">
            <div class="w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-6 border border-brand-primary/20 bg-blend-soft-light transition-transform group-hover:scale-110">
               <i class="fa-solid fa-microchip text-xl"></i>
            </div>
            <h3 class="font-display font-medium text-2xl text-surface-text mb-3">{t('features.1.title')}</h3>
            <p class="text-surface-muted leading-relaxed max-w-lg">{t('features.1.desc')}</p>
        </div>
      </div>

      <div class="bg-surface-card rounded-3xl flex flex-col relative min-h-[320px] border border-surface-border shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <img
          src="/images/screenshots/iPhone-14-500w.webp"
          alt="Mobile View Aplikasi PARKIN di iPhone"
          class="absolute bottom-0 right-0 w-3/4 opacity-90 iphone-float"
          width="500"
          height="1054"
          loading="lazy"
          decoding="async"
          srcset="/images/screenshots/iPhone-14-500w.webp 500w, /images/screenshots/iPhone-14.webp 1080w"
          sizes="(max-width: 768px) 279px, 229px"
        />
         <div class="relative z-10 p-10 h-full flex flex-col justify-start bg-gradient-to-b from-surface-card via-surface-card/90 to-transparent pointer-events-none">
             <div class="w-12 h-12 rounded-xl bg-surface-bg text-surface-text flex items-center justify-center mb-6 border border-surface-border transition-transform group-hover:scale-110">
                <i class="fa-solid fa-mobile-screen-button"></i>
             </div>
             <h3 class="font-display font-medium text-lg text-surface-text mb-3">{t('features.3.title')}</h3>
             <p class="text-surface-muted text-sm leading-relaxed pb-10">{t('features.3.desc')}</p>
         </div>
      </div>

      <!-- Card 3: Real-Time -->
      <div class="bg-surface-card p-10 rounded-3xl flex flex-col justify-end min-h-[320px] relative overflow-hidden group border border-surface-border shadow-sm hover:shadow-lg transition-all duration-300">
         <div class="absolute top-12 right-12 opacity-60 pointer-events-none">
            <div class="w-14 h-14 rounded-full border-2 border-brand-secondary/30 flex items-center justify-center relative">
                <div class="absolute inset-0 rounded-full border border-brand-secondary/50 animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></div>
                <div class="w-3 h-3 rounded-full bg-brand-secondary animate-pulse"></div>
            </div>
         </div>
         <div class="relative z-10 mt-24 h-full flex flex-col justify-end">
             <div class="w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-6 border border-brand-primary/20 transition-transform group-hover:scale-110">
                <i class="fa-solid fa-bolt text-xl"></i>
             </div>
             <h3 class="font-display font-medium text-xl text-surface-text mb-3">{t('features.2.title')}</h3>
             <p class="text-surface-muted text-sm leading-relaxed">{t('features.2.desc')}</p>
         </div>
      </div>

      <!-- Card 4: Integration -->
      <div class="md:col-span-2 bg-surface-card p-10 rounded-3xl flex flex-col md:flex-row items-start md:items-center justify-between gap-6 border border-surface-border shadow-sm hover:shadow-lg transition-all duration-300 group">
        <div>
            <div class="w-12 h-12 rounded-xl bg-surface-bg text-surface-text flex items-center justify-center mb-4 border border-surface-border transition-transform group-hover:scale-110">
                <i class="fa-solid fa-code"></i>
            </div>
            <h3 class="font-display font-medium text-xl text-surface-text mb-3">{t('features.4.title')}</h3>
            <p class="text-surface-muted text-sm max-w-lg leading-relaxed">{t('features.4.desc')}</p>
        </div>
        <div class="shrink-0 flex items-center justify-center relative w-full md:w-auto mt-8 md:mt-0">
            <div class="relative h-48 w-[280px] mx-auto select-none pointer-events-none">
                <svg class="absolute inset-0 w-[280px] h-[192px]" viewBox="0 0 280 192" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                    <path d="M 45 40 Q 92 40 116 68 T 140 96" stroke="var(--color-brand-primary)" stroke-width="2" fill="none" opacity="0.5"></path>
                    <path d="M 235 40 Q 188 40 164 68 T 140 96" stroke="var(--color-brand-primary)" stroke-width="2" fill="none" opacity="0.5"></path>
                    <path d="M 45 152 Q 92 152 116 124 T 140 96" stroke="var(--color-status-ok)" stroke-width="2" fill="none" opacity="0.5"></path>
                    <path d="M 235 152 Q 188 152 164 124 T 140 96" stroke="var(--color-status-ok)" stroke-width="2" fill="none" opacity="0.5"></path>
                    
                    <!-- Titik-titik bergerak di atas path — menggunakan animateMotion yang GPU-composited -->
                    <circle r="3" fill="var(--color-brand-primary)" opacity="0.8">
                      <animateMotion dur="2s" repeatCount="indefinite" begin="0s">
                        <mpath href="#path-tl"/>
                      </animateMotion>
                    </circle>
                    <circle r="3" fill="var(--color-brand-primary)" opacity="0.8">
                      <animateMotion dur="2s" repeatCount="indefinite" begin="-0.5s">
                        <mpath href="#path-tr"/>
                      </animateMotion>
                    </circle>
                    <circle r="3" fill="var(--color-status-ok)" opacity="0.8">
                      <animateMotion dur="2s" repeatCount="indefinite" begin="-1s">
                        <mpath href="#path-bl"/>
                      </animateMotion>
                    </circle>
                    <circle r="3" fill="var(--color-status-ok)" opacity="0.8">
                      <animateMotion dur="2s" repeatCount="indefinite" begin="-1.5s">
                        <mpath href="#path-br"/>
                      </animateMotion>
                    </circle>
                    
                    <!-- Path definitions dengan id untuk animateMotion reference -->
                    <defs>
                      <path id="path-tl" d="M 45 40 Q 92 40 116 68 T 140 96"/>
                      <path id="path-tr" d="M 235 40 Q 188 40 164 68 T 140 96"/>
                      <path id="path-bl" d="M 45 152 Q 92 152 116 124 T 140 96"/>
                      <path id="path-br" d="M 235 152 Q 188 152 164 124 T 140 96"/>
                    </defs>
                </svg>

                <!-- Central Hub -->
                <div class="absolute w-12 h-12 bg-surface-card border-2 border-brand-primary/50 shadow-glow-blue rounded-xl flex items-center justify-center z-20 animate-[pulse_3s_ease-in-out_infinite]" style="top: 72px; left: 116px;">
                    <i class="fa-solid fa-server text-brand-primary text-xl" aria-hidden="true"></i>
                </div>

                <!-- Integration Icons -->
                <div class="absolute w-10 h-10 bg-surface-bg border border-surface-border shadow-sm rounded-xl flex items-center justify-center z-10 transition-transform group-hover:scale-110" style="top: 20px; left: 25px;">
                    <i class="fa-brands fa-python text-status-warn text-lg" aria-hidden="true"></i>
                </div>
                <div class="absolute w-10 h-10 bg-surface-bg border border-surface-border shadow-sm rounded-xl flex items-center justify-center z-10 transition-transform group-hover:scale-110" style="top: 20px; left: 215px;">
                    <i class="fa-solid fa-network-wired text-brand-primary text-sm" aria-hidden="true"></i>
                </div>
                <div class="absolute w-10 h-10 bg-surface-bg border border-surface-border shadow-sm rounded-xl flex items-center justify-center z-10 transition-transform group-hover:scale-110" style="top: 132px; left: 25px;">
                    <i class="fa-solid fa-database text-status-ok text-sm" aria-hidden="true"></i>
                </div>
                <div class="absolute w-10 h-10 bg-surface-bg border border-surface-border shadow-sm rounded-xl flex items-center justify-center z-10 transition-transform group-hover:scale-110" style="top: 132px; left: 215px;">
                    <i class="fa-solid fa-display text-brand-accent text-sm" aria-hidden="true"></i>
                </div>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .iphone-float {
    transform: translateX(1rem) translateY(1rem);
    animation: iphoneFloat 6s ease-in-out infinite;
    will-change: transform; 
  }

  @keyframes iphoneFloat {
    0%   { transform: translateX(1rem) translateY(1rem); }
    50%  { transform: translateX(1rem) translateY(-0.5rem); }
    100% { transform: translateX(1rem) translateY(1rem); }
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
</style>